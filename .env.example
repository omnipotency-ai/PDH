# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Stripe — add to .env.local for Vite, and STRIPE_SECRET_KEY to Convex env
# Create products/prices at https://dashboard.stripe.com/products
VITE_STRIPE_MONTHLY_PRICE_ID="price_xxx"
VITE_STRIPE_LIFETIME_PRICE_ID="price_xxx"
# Set in Convex dashboard (Settings > Environment Variables):
# STRIPE_SECRET_KEY="sk_test_xxx"

# E2E Testing — Clerk test user credentials
# IMPORTANT: The test user MUST exist in Clerk Dashboard before running E2E tests.
# 
# Steps to set up E2E testing:
# 1. In Clerk Dashboard, ensure Email authentication is enabled
# 2. Create a test user with email containing +clerk_test (e.g., e2e+clerk_test@opusrocks.ai)
#    - Users with +clerk_test bypass email verification using magic code 424242
# 3. Set the env vars below (without quotes around values)
#
# E2E_CLERK_USER_EMAIL=e2e+clerk_test@opusrocks.ai
#
# Optional: If using password auth instead of email_code:
# E2E_CLERK_USER_PASSWORD=your-test-password
#
# Required: Clerk secret key for testing token generation
# CLERK_SECRET_KEY=sk_test_xxx
